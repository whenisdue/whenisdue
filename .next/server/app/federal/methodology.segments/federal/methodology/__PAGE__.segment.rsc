19:["$","div",null,{"className":"space-y-4 text-slate-700 mb-10","children":[[["$","p","0",{"children":"Benefit amounts can change even when payment dates stay the same. This is often misread as an outage."}],["$","p","1",{"children":"To prevent outdated guidance, we maintain a build-time registry of official policy anchors (SSA and SNAP)."}],["$","p","2",{"children":"If a new rule source is missing—or a new SNAP state enters our ledger without amount-rule coverage—the site build fails until a human reviews and updates the registry."}],["$","p","3",{"children":"We do not estimate your personal benefit amount. We provide deterministic, provenance-linked rule explanations only."}]],["$","ul",null,{"className":"list-disc pl-6 space-y-2 mt-4","children":[["$","li","0",{"children":"No live scraping is used for amount explanations."}],["$","li","1",{"children":"No speculative or personalized amount claims are generated."}],["$","li","2",{"children":"Missing coverage triggers a fail-closed build error."}]]}]]}]
