{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/ops/layout,_N_T_/ops/witnesses/layout,_N_T_/ops/witnesses/page,_N_T_/ops/witnesses"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/ops/witnesses/__PAGE__",
    "/ops/witnesses",
    "/ops",
    "/_index",
    "/_head"
  ]
}