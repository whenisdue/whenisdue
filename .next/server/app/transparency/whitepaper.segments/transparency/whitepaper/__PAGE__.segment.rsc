10:["$","div",null,{"className":"space-y-6 mb-10","children":[["$","div",null,{"className":"p-5 bg-slate-50 rounded-xl border border-slate-200","children":[["$","h3",null,{"className":"font-semibold text-slate-900","children":"A) Completeness Guard (Coverage Moat)"}],["$","p",null,{"className":"text-slate-700 mt-1 text-sm","children":"Ensures that if a program/state exists in our core schedule ledger, it also has complete official links in our override registries. Prevents partial coverage."}]]}],["$","div",null,{"className":"p-5 bg-slate-50 rounded-xl border border-slate-200","children":[["$","h3",null,{"className":"font-semibold text-slate-900","children":"B) Drift Guard (Schedule Moat)"}],["$","p",null,{"className":"text-slate-700 mt-1 text-sm","children":"Ensures our deterministic calendar dates match official publication version stamps (e.g., SSA Publication IDs). If an agency publishes a new rule year, the build fails until a human reviews it."}]]}],["$","div",null,{"className":"p-5 bg-slate-50 rounded-xl border border-slate-200","children":[["$","h3",null,{"className":"font-semibold text-slate-900","children":"C) Amount Drift Guard (Explanation Moat)"}],["$","p",null,{"className":"text-slate-700 mt-1 text-sm","children":"Ensures our “Amount Shock” explanations (e.g., Medicare premium deductions or SNAP SUA updates) are backed by active, verified policy URLs. We do not calculate amounts; we pin the rules that govern them."}]]}],["$","div",null,{"className":"p-5 bg-slate-50 rounded-xl border border-slate-200","children":[["$","h3",null,{"className":"font-semibold text-slate-900","children":"D) Cross-Program Coupling Layer"}],["$","p",null,{"className":"text-slate-700 mt-1 text-sm","children":"Some public benefits are coupled: a rule-based change in one program (like a Social Security COLA) can trigger a predictable adjustment in another (like SNAP). This layer publishes categorical explanations for common couplings to prevent users from mistaking a policy-driven reduction for an outage. We never estimate personal impacts."}]]}]]}]
