{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/verify/layout,_N_T_/verify/mirrors/layout,_N_T_/verify/mirrors/page,_N_T_/verify/mirrors"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/verify/mirrors/__PAGE__",
    "/verify/mirrors",
    "/verify",
    "/_index",
    "/_head"
  ]
}