{
  "schemaVersion": "2026-02-amount-drift-guard.v1",
  "purpose": "Build-fail registry for deterministic monitoring of benefit amount formula changes (SSA/SSI/SSDI + SNAP). No live scraping. No speculation.",
  "lastHumanReviewPolicy": {
    "principle": "Fail closed when a material amount-rule anchor is missing. Human review required to update URLs/provenance keys and (if needed) explanatory copy.",
    "notes": [
      "This registry does not attempt to compute benefit amounts.",
      "This registry provides provenance-linked anchors that define the rule sources for common 'amount shock' causes.",
      "If new SNAP states are added to events.json, this registry must be extended for those states or the build fails."
    ]
  },
  "ssa": {
    "requiredAnchors": [
      {
        "id": "SSA_TOP_TREASURY_OFFSET",
        "label": "Treasury Offset Program (TOP) offsets from Social Security payments",
        "provenanceKey": "SSA_TOP_TREASURY_OFFSET",
        "url": "https://www.ssa.gov/OP_Home/cfr20/404/404-1820.htm",
        "whyItMatters": "Offsets can reduce net payments; commonly misinterpreted as a payment error or outage."
      },
      {
        "id": "SSA_MEDICARE_PARTB_PREMIUMS",
        "label": "Medicare Part B premiums withheld from Social Security benefits",
        "provenanceKey": "SSA_MEDICARE_PARTB_PREMIUMS",
        "url": "https://www.ssa.gov/benefits/medicare/",
        "whyItMatters": "Annual premium changes can reduce the net check even when gross benefits rise."
      },
      {
        "id": "CMS_PARTB_PREMIUM_RATES",
        "label": "CMS: Medicare Part B premium rates (annual updates)",
        "provenanceKey": "CMS_PARTB_PREMIUM_RATES",
        "url": "https://www.medicare.gov/basics/costs/medicare-costs",
        "whyItMatters": "Grounds the amount withheld in official rate tables."
      },
      {
        "id": "SSA_IRMAA_MEDICARE_ADJUSTMENT",
        "label": "IRMAA: Income-Related Monthly Adjustment Amount (Medicare premium surcharges)",
        "provenanceKey": "SSA_IRMAA_MEDICARE_ADJUSTMENT",
        "url": "https://www.ssa.gov/benefits/medicare/medicare-premiums.html",
        "whyItMatters": "Higher-income beneficiaries may see net reductions due to surcharges."
      },
      {
        "id": "SSA_COLA_POLICY",
        "label": "COLA policy and application to benefits",
        "provenanceKey": "SSA_COLA_POLICY",
        "url": "https://www.ssa.gov/cola/",
        "whyItMatters": "Explains why changes occur at year boundaries and why net may differ."
      },
      {
        "id": "SSA_OVERPAYMENT_RECOVERY",
        "label": "Overpayment recovery and withholding policy",
        "provenanceKey": "SSA_OVERPAYMENT_RECOVERY",
        "url": "https://www.ssa.gov/benefits/retirement/planner/claiming.html",
        "whyItMatters": "Withholding for recovery can reduce checks; users often interpret as missing funds."
      }
    ],
    "uiBannerPolicy": {
      "renderWhen": [
        "ctx.amountFriction?.ssa === true"
      ],
      "copyKey": "SSA_AMOUNT_SHOCK",
      "mustInclude": [
        "Not an outage",
        "Common deterministic causes list",
        "Official provenance links",
        "No individualized amount promises"
      ]
    }
  },
  "snap": {
    "requiredPerStateAnchorTypes": [
      "SUA",
      "DEDUCTIONS",
      "SYSTEM"
    ],
    "stateDefaults": {
      "notes": [
        "SUA anchors should point to the state DSS/HHS policy/manual page that defines Standard Utility Allowances or deduction rules.",
        "DEDUCTIONS anchors should ground shelter/utility/internet deduction logic or related federal/state policy pages.",
        "SYSTEM anchors should point to the state’s system modernization / program guidance page where recalculation or EDBC changes are documented (if applicable)."
      ]
    },
