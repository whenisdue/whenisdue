generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["typedSql"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum EventCategory {
  FEDERAL
  STATE
  TAX
  MARKETS
  GAMING
  SHOPPING
  TECH
  OTHER
}

enum EventDateStatus {
  EXACT
  TBA
  TBD_MONTH
  TBD_QUARTER
  TBD_YEAR
}

enum RecurrenceType {
  NONE
  MONTHLY_FIXED_DAY
  MONTHLY_NTH_WEEKDAY
  MANUAL_DATES
}

enum EventStatus {
  ANNOUNCED
  CONFIRMED
  LIVE
  COMPLETED
}

enum SubmissionStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  DUPLICATE
}

enum NotificationChannel {
  EMAIL
  PUSH
}

enum DeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED_RETRYABLE
  FAILED_FINAL
  INVALID_ENDPOINT
}

// ==========================================
// THE DATA ENGINE
// ==========================================

model EventSeries {
  id                  String         @id @default(cuid())
  title               String
  slugBase            String         @unique
  category            EventCategory
  description         String?
  isFeatured          Boolean        @default(false)
  priorityWeight      Int            @default(5)
  heroQuestion        String?
  status              EventStatus    @default(CONFIRMED)
  sourceName          String?
  sourceUrl           String?

  recurrenceType        RecurrenceType @default(NONE)
  dayOfMonth            Int?
  nthWeek               Int?
  weekday               Int?
  startMonth            DateTime?
  endMonth              DateTime?
  autoAdjustBusinessDay Boolean        @default(false)
  generateCount         Int?
  isActive              Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

model Event {
  id       String       @id @default(cuid())
  seriesId String?
  series   EventSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  slug     String        @unique
  title    String
  category EventCategory

  dueAt      DateTime?
  timeZone   String?
  dateStatus EventDateStatus @default(EXACT)

  displayYear    Int?
  displayMonth   Int?
  displayQuarter Int?
  dateLabel      String?

  trending    Boolean @default(false)
  isGenerated Boolean @default(false)
  isDetached  Boolean @default(false)

  seoTitle       String?
  seoDescription String?
  keywords       String?
  sourceUrl      String?
  lastVerified   DateTime?

  shortSummary     String?
  whatToExpect     String?
  whereToWatch     String?
  expectedDuration String?
  targetAudience   String?

  // PHASE 4: Deep Data Enrichment (Hybrid JSON columns)
  scheduleRules Json?    // Stores the complex table data (e.g., EDG ranges -> Dates)
  faqData       Json?    // Stores the anxiety-driven Q&A pairs

  isArchived  Boolean         @default(false)
  clickStat   EventClickStat?
  titleSearch String?         @map("titleSearch") // Generated by SQL Migration

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dateStatus, dueAt])
  @@index([dueAt])
  @@index([seriesId, dueAt])
}

model EventClickStat {
  id            String    @id @default(cuid())
  eventId       String    @unique
  totalClicks   Int       @default(0)
  clickCount1h  Int       @default(0)
  clickCount24h Int       @default(0)
  lastClickAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([clickCount1h])
  @@index([clickCount24h])
  @@index([lastClickAt])
}

// ==========================================
// REQUEST & MODERATION ENGINE
// ==========================================

model EventSubmission {
  id              String           @id @default(cuid())
  status          SubmissionStatus @default(PENDING)
  submittedTitle  String
  submittedDate   String?
  submittedSource String?
  submitterIpHash String?
  userAgent       String?
  honeypot        String?
  reviewerNotes   String?
  duplicateOfId   String?
  titleSearch     String?          @map("titleSearch") // Generated by SQL Migration

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// ==========================================
// NOTIFICATION ENGINE
// ==========================================

model NotificationDelivery {
  id                   String              @id @default(cuid())
  eventId              String
  channel              NotificationChannel
  recipientFingerprint String
  status               DeliveryStatus      @default(PENDING)
  attemptCount         Int                 @default(0)
  dedupeKey            String              @unique
  errorLog             String?
  providerMessageId    String?
  scheduledFor         DateTime
  sentAt               DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([status, scheduledFor])
  @@index([eventId])
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String?
  endpoint     String   @unique
  p256dh       String
  auth         String
  isValid      Boolean  @default(true)
  failureCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model UserTopicSubscription {
  id         String  @id @default(cuid())
  userId     String
  topicKey   String
  wantsEmail Boolean @default(false)
  wantsPush  Boolean @default(false)

  @@unique([userId, topicKey])
}

// ==========================================
// SECURITY & ANALYTICS
// ==========================================

model IpRateLimit {
  ipHash       String
  routeKey     String
  windowStart  DateTime
  requestCount Int      @default(0)
  lastSeenAt   DateTime @default(now())

  @@id([ipHash, routeKey, windowStart])
  @@index([lastSeenAt])
}

model PageStat {
  id              String   @id @default(cuid())
  routePath       String   @unique
  slug            String?
  pageViews       Int      @default(0)
  uniquePageViews Int      @default(0)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model PageViewDedup {
  id         String   @id @default(cuid())
  dedupeKey  String   @unique
  routePath  String
  visitorId  String
  bucketDate String
  createdAt  DateTime @default(now())

  @@index([routePath, bucketDate])
}

// ==========================================
// PATH B: THE PROGRAMMATIC NOTIFICATION ENGINE
// ==========================================

enum Channel {
  EMAIL
  SMS
}

enum SubStatus {
  PENDING_VERIFICATION
  ACTIVE
  PAUSED
  OUTDATED
}

model Subscriber {
  id            String   @id @default(cuid())
  channel       Channel
  
  // Security: contactValue will be encrypted at the application layer.
  // contactHash is a SHA-256 hash used for safe deduplication/lookups.
  contactValue  String   @unique
  contactHash   String   @unique 
  
  // Timezone-aware delivery (e.g., "America/New_York")
  timezone      String   @default("America/New_York") 
  
  createdAt     DateTime @default(now())

  subscriptions Subscription[]
  tokens        VerificationToken[]
}

model Subscription {
  id              String     @id @default(cuid())
  subscriberId    String
  subscriber      Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  
  // The Rule (Program-Agnostic)
  state           String     // e.g., "Texas"
  program         String     // e.g., "SNAP"
  ruleGroup       String     // e.g., "SSN ending in 4" (Legacy backward compatibility)
  
  // RESEARCH APPLIED: Data Minimization. We only store the exact isolated digits needed.
  identifierValue String?    // e.g., "07" or "A"
  
  status          SubStatus  @default(PENDING_VERIFICATION)
  isActive        Boolean    @default(true)
  ruleVersion     Int        @default(1)
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  outbox          NotificationOutbox[]
}

// RESEARCH APPLIED: Canonical RulePack Schema
model ScheduleRule {
  id              String         @id @default(cuid())
  state           String
  program         String
  ruleType        String         // e.g., "DIGIT_RANGE_BUCKET", "SINGLE_DIGIT_SEQUENCE"
  identifierKind  String         // e.g., "case_last_digit", "edg_last_two_digits"
  
  // Storing the actual math/logic in JSON format so the engine can interpret it without code changes
  logicPayload    Json           
  
  // RESEARCH APPLIED: Explicit holiday/weekend handling rules
  calendarPolicy  Json           
  
  events          PaymentEvent[] 
}

// RESEARCH APPLIED: Forecast Instances
model PaymentEvent {
  id               String       @id @default(cuid())
  scheduleRuleId   String
  month            String       // e.g., '2026-03'
  depositDate      DateTime     
  identifierMatch  String       // e.g., '04'

  rule             ScheduleRule @relation(fields: [scheduleRuleId], references: [id])

  // RESEARCH APPLIED: Batch 2, Tab 1 (B-Tree Indexing Strategy)
  // Index 1: The "Page Index" (Optimized for full-month schedule page loads)
  @@index([scheduleRuleId, month, depositDate, identifierMatch])

  // Index 2: The "Precise Lookup Index" (Optimized for instant search dropdowns)
  @@index([scheduleRuleId, identifierMatch, month])
}

// Double Opt-In Security
model VerificationToken {
  id           String     @id @default(cuid())
  subscriberId String
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  
  token        String     @unique // 6-digit OTP for SMS, or CUID for Email
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
}

// The Idempotent Delivery Ledger (Prevents double-texting)
model NotificationOutbox {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  // Unique constraint prevents duplicate jobs (e.g., "sub123_mar2026")
  dedupeKey       String       @unique 
  
  status          String       @default("PENDING") // PENDING, SENT, FAILED
  sendAt          DateTime     // The exact UTC time this should fire
  
  providerMsgId   String?      // Twilio or Resend receipt ID
  lastError       String?
  
  createdAt       DateTime     @default(now())
  sentAt          DateTime?
}