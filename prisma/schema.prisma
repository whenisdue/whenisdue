generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["typedSql"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum IdentifierMatchType {
  CASE_NUMBER_LAST_DIGIT
  CASE_NUMBER_REMAINDER
  LAST_NAME_INITIAL
  BIRTH_DATE_DAY
}

enum DecisionReason {
  SSN_LAST_DIGIT
  SSN_LAST_TWO_DIGITS
  CASE_NUMBER_LAST_DIGIT
  CASE_NUMBER_LAST_TWO_DIGITS
  CLIENT_ID_MODULO
  NAME_ALPHABETICAL_GROUP
  WEEKEND_SHIFT_FORWARD
  WEEKEND_SHIFT_BACKWARD
  FEDERAL_HOLIDAY_SHIFT_FORWARD
  FEDERAL_HOLIDAY_SHIFT_BACKWARD
  EARLY_ISSUANCE_PRE_HOLIDAY
  FLORIDA_REVERSED_DIGIT_LOGIC
  TEXAS_SPLIT_SCHEDULE
  CALIFORNIA_COUNTY_BASED
  NEW_YORK_BOROUGH_DISTRIBUTION
  STATE_MANUAL_OVERRIDE
  INITIAL_APPLICATION_ISSUANCE
  EXPEDITED_BENEFITS
  RETROACTIVE_BENEFITS
  DISASTER_SNAP_DSNAP
  SUPPLEMENTAL_BENEFIT
  CORRECTIVE_ADJUSTMENT
  BIRTH_DATE_RANGE
  HOUSEHOLD_SIZE_GROUP
  BENEFIT_GROUP_PHASE
  GEOGRAPHIC_STAGGER
  CASELOAD_DISTRIBUTION
  SYSTEM_BATCH_PROCESSING
  PAYMENT_CYCLE_STANDARD
  MIGRATION_LEGACY_SYSTEM
  MANUAL_ADMIN_OVERRIDE
}

enum EventCategory {
  FEDERAL
  STATE
  TAX
  MARKETS
  GAMING
  SHOPPING
  TECH
  OTHER
}

enum EventDateStatus {
  EXACT
  TBA
  TBD_MONTH
  TBD_QUARTER
  TBD_YEAR
}

enum RecurrenceType {
  NONE
  MONTHLY_FIXED_DAY
  MONTHLY_NTH_WEEKDAY
  MANUAL_DATES
}

enum EventStatus {
  ANNOUNCED
  CONFIRMED
  LIVE
  COMPLETED
}

enum SubmissionStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  DUPLICATE
}

enum NotificationChannel {
  EMAIL
  PUSH
}

enum DeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED_RETRYABLE
  FAILED_FINAL
  INVALID_ENDPOINT
}

enum RuleStatus {
  DRAFT
  REVIEWED
  VERIFIED
  ACTIVE
  SUPERSEDED
}

enum ShiftCause {
  WEEKEND
  HOLIDAY
  BUSINESS_DAY
  NONE
}

enum AppliedPolicy {
  PREVIOUS_BUSINESS_DAY
  NEXT_BUSINESS_DAY
  SAME_DAY
  NO_SHIFT
}

enum OutboxStatus { 
  PENDING
  CLAIMED
  RETRY_SCHEDULED
  SENT
  DEAD_LETTER 
}

enum AttemptOutcome { 
  SUCCESS
  TRANSIENT_FAILURE
  PERMANENT_FAILURE
  PROVIDER_REJECTION 
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
}

enum VerificationStatus {
  PROVISIONAL
  VERIFIED
  OFFICIAL_API
  COMMUNITY_CONSENSUS
}

enum TriggerType {
  CASE_DIGIT
  ALPHABETIC_RANGE
  SSN_LAST_FOUR
  MONTHLY_STATIC
  MONTH_SPECIFIC
  WEEK_NUMBER
  NUMERIC_RANGE
}

enum DateOffsetStrategy {
  PREV_BUSINESS_DAY
  NEXT_BUSINESS_DAY
  NEAREST_BUSINESS_DAY
  EXACT_CALENDAR_DATE
  NO_SHIFT
  WEEKEND_SENSITIVE
  BUSINESS_DAY_STAGGER
}

enum CohortType {
  PRE_JUNE_2020
  POST_JUNE_2020
  NYC_A_CYCLE
  NYC_B_CYCLE
  UPSTATE
  STANDARD
  GEORGIA_STANDARD
}

enum PersistenceReason {
  SCHEDULED_TRIGGER_MET
  INACTIVE
  ALREADY_PAID
  ALREADY_NOTIFIED
  OUTSIDE_SCHEDULED_DATE
  INCONSISTENT_STATE
  INTEGRITY_CONFLICT_ALREADY_SENT
  BLOCK_IN_FLIGHT_EXISTS
  BLOCK_RETRY_EXISTS
  TERMINAL_FAILURE_ENCOUNTERED
  MANUAL_RETRY_TRIGGERED
}

// ==========================================
// CLARITY ENGINE (SMART DATES)
// ==========================================

model State {
  id           String     @id @default(cuid())
  name         String     @unique
  slug         String     @unique
  abbreviation String     @unique
  officialUrl  String?
  programs     Program[]
  resources    Resource[]
}

model Program {
  id           String        @id @default(cuid())
  name         String
  category     String
  stateId      String
  state        State         @relation(fields: [stateId], references: [id])
  rules        Rule[]
  manualEvents ManualEvent[]

  @@unique([stateId, name], name: "program_identity")
}

model Rule {
  id              String             @id @default(cuid())
  programId       String
  program         Program            @relation(fields: [programId], references: [id])
  
  cohortKey       CohortType         @default(STANDARD)
  
  triggerType     TriggerType
  triggerStart    String             
  triggerEnd      String?            
  
  baseDay         Int                
  offsetStrategy  DateOffsetStrategy @default(PREV_BUSINESS_DAY)
  
  sourceCitation  String?            
  version         Int                @default(1)
  updatedAt       DateTime           @updatedAt

  @@unique([programId, cohortKey, triggerStart, triggerEnd], name: "rule_uniqueness")
}

model ManualEvent {
  id              String   @id @default(cuid())
  programId       String
  program         Program  @relation(fields: [programId], references: [id])
  title           String   
  dueAt           DateTime
  sourceCitation  String?
}

model Resource {
  id      String @id @default(cuid())
  stateId String
  state   State  @relation(fields: [stateId], references: [id])
  type    String 
  name    String
  value   String
}

// ==========================================
// CORE DATA ENGINE
// ==========================================

model EventSeries {
  id                    String         @id @default(cuid())
  title                 String
  slugBase              String         @unique
  category              EventCategory
  description           String?
  isFeatured            Boolean        @default(false)
  priorityWeight        Int            @default(5)
  heroQuestion          String?
  status                EventStatus    @default(CONFIRMED)
  sourceName            String?
  sourceUrl             String?
  recurrenceType        RecurrenceType @default(NONE)
  dayOfMonth            Int?
  nthWeek               Int?
  weekday               Int?
  startMonth            DateTime?
  endMonth              DateTime?
  autoAdjustBusinessDay Boolean        @default(false)
  generateCount         Int?
  isActive              Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  events                Event[]
}

model Event {
  id                String          @id @default(cuid())
  seriesId          String?
  series            EventSeries?    @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  slug              String          @unique
  title             String
  category          EventCategory
  dueAt             DateTime?
  timeZone          String?
  dateStatus        EventDateStatus @default(EXACT)
  displayYear       Int?
  displayMonth      Int?
  displayQuarter    Int?
  dateLabel         String?
  trending          Boolean         @default(false)
  isGenerated       Boolean         @default(false)
  isDetached        Boolean         @default(false)
  seoTitle          String?
  seoDescription    String?
  keywords          String?
  sourceUrl          String?
  lastVerified      DateTime?

  verificationStatus VerificationStatus @default(PROVISIONAL)
  confidenceScore    Float              @default(0.5)

  shortSummary      String?
  whatToExpect      String?
  whereToWatch      String?
  expectedDuration String?
  targetAudience    String?
  scheduleRules    Json?
  faqData          Json?
  isArchived        Boolean         @default(false)
  clickStat         EventClickStat?
  titleSearch       String?         @map("titleSearch")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([dateStatus, dueAt])
  @@index([dueAt])
  @@index([seriesId, dueAt])
}

model EventClickStat {
  id            String    @id @default(cuid())
  eventId       String    @unique
  totalClicks    Int       @default(0)
  clickCount1h  Int       @default(0)
  clickCount24h Int       @default(0)
  lastClickAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([clickCount1h])
  @@index([clickCount24h])
  @@index([lastClickAt])
}

// ==========================================
// INFRASTRUCTURE & ANALYTICS
// ==========================================

model PageStat {
  id              String   @id @default(cuid())
  routePath       String   @unique
  slug            String?
  pageViews       Int      @default(0)
  uniquePageViews Int      @default(0)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model PageViewDedup {
  id         String   @id @default(cuid())
  dedupeKey  String   @unique
  routePath  String
  visitorId  String
  bucketDate String
  createdAt  DateTime @default(now())

  @@index([routePath, bucketDate])
}

model IpRateLimit {
  ipHash       String
  routeKey     String
  windowStart  DateTime
  requestCount Int      @default(0)
  lastSeenAt   DateTime @default(now())

  @@id([ipHash, routeKey, windowStart])
  @@index([lastSeenAt])
}

model EventSubmission {
  id              String           @id @default(cuid())
  status          SubmissionStatus @default(PENDING)
  submittedTitle  String
  submittedDate   String?
  submittedSource String?
  submitterIpHash String?
  userAgent       String?
  honeypot        String?
  reviewerNotes   String?
  duplicateOfId   String?
  titleSearch     String?          @map("titleSearch")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status, createdAt])
}

// ==========================================
// HARDENED SUBSCRIPTION TIER
// ==========================================

model Subscriber {
  id              String         @id @default(cuid())
  email           String         @unique
  normalizedEmail String         @unique
  verifiedEmail   String?
  emailVerifiedAt DateTime?
  unsubscribedAt  DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  subscriptions   Subscription[]
}

model Subscription {
  id                String              @id @default(cuid())
  subscriberId      String
  stateCode         String   
  programCode       String   
  identifierValue   String   
  status            SubscriptionStatus @default(ACTIVE)
  
  nextDepositDate DateTime           @db.Date 
  
  nextDepositReason  DecisionReason  @default(PAYMENT_CYCLE_STANDARD)
  nextDepositDetails Json?            

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  subscriber        Subscriber         @relation(fields: [subscriberId], references: [id])
  decisions         NotificationDecisionAudit[]

  @@unique([subscriberId, stateCode, programCode, identifierValue], name: "subscription_identity_key")
  @@index([subscriberId])
}

model RequestLog {
  internalId     String   @id @default(cuid())
  idempotencyKey String   
  subscriberId   String
  action         String   
  payloadHash    String   
  responseStatus Int
  responseBody   Json     
  createdAt      DateTime @default(now())

  @@unique([subscriberId, action, idempotencyKey], name: "request_idempotency_key")
}

// ==========================================
// BITEMPORAL LEDGER & AUDIT ENGINE
// ==========================================

model RuleIdentity {
  id                  String            @id @default(cuid())
  stateCode           String
  programCode         String
  ruleFamily          String            @default("FULL_SCHEDULE")
  versions            ScheduleRuleSet[]
  allowsSubscriptions Boolean           @default(true) 
  isSearchable        Boolean           @default(true) 

  @@unique([stateCode, programCode, ruleFamily])
}

model ScheduleRuleSet {
  supersedesId       String?
  id                 String            @id @default(cuid())
  identityId         String
  identity           RuleIdentity      @relation(fields: [identityId], references: [id])
  validFrom          DateTime
  validTo            DateTime?
  createdAt          DateTime          @default(now())
  
  recordedFrom       DateTime          @default(now())
  recordedTo         DateTime?
  status             RuleStatus        @default(DRAFT)
  versionNumber      Int               @default(1)
  changeReason       String?
  verifiedAt         DateTime?
  verifiedBy         String?
  
  identifierKind     String
  issuanceWindow     String
  windowBasis        String
  holidayPolicy      String
  masterSequenceJson Json
  sourceAuthority    String
  sourceUrl          String
  
  paymentEvents      PaymentEvent[]
  notificationAudits NotificationDecisionAudit[]

  @@index([identityId, recordedFrom, recordedTo])
}

model CompilerRun {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())
  compilerVersion     String
  initiatedBy         String?
  note                String?
  paymentEvents       PaymentEvent[]
  notificationAudits NotificationDecisionAudit[]
}

model PaymentEvent {
  id                  String           @id @default(cuid())
  createdAt           DateTime         @default(now())
  batchId             String
  batch               CompilerRun      @relation(fields: [batchId], references: [id])
  ruleSetId           String
  ruleSet             ScheduleRuleSet  @relation(fields: [ruleSetId], references: [id])
  
  recordedFrom       DateTime          @default(now())
  recordedTo         DateTime?
  
  stateCode          String
  programCode        String
  benefitYear        Int
  benefitMonth       Int
  nominalDepositDay  Int
  depositDate        DateTime
  identifierKind     String
  identifierMatch    String

  reason              DecisionReason   @default(PAYMENT_CYCLE_STANDARD)
  reasonDetails       Json?            

  isShifted          Boolean          @default(false)
  shiftCause          ShiftCause       @default(NONE)
  appliedPolicy      AppliedPolicy    @default(NO_SHIFT)

  auditsAsOld        NotificationDecisionAudit[] @relation("OldEvent")
  auditsAsNew        NotificationDecisionAudit[] @relation("NewEvent")

  @@index([stateCode, programCode, benefitYear, benefitMonth, recordedFrom, recordedTo])
}

model NotificationDecisionAudit {
  id                  String                @id @default(cuid())
  subscriptionId      String
  cycleKey            String                
  notificationType    String                
  channel             String                
  persistenceReason   PersistenceReason  
  
  ruleSetVersionId    String
  ruleSet             ScheduleRuleSet    @relation(fields: [ruleSetVersionId], references: [id])
  compilerRunId       String
  compilerRun         CompilerRun        @relation(fields: [compilerRunId], references: [id])
  oldEventId          String?
  oldEvent            PaymentEvent?      @relation("OldEvent", fields: [oldEventId], references: [id])
  newEventId          String?
  newEvent            PaymentEvent?      @relation("NewEvent", fields: [newEventId], references: [id])
  
  metadata            Json?                

  createdAt           DateTime             @default(now())
  subscription        Subscription         @relation(fields: [subscriptionId], references: [id])
  outboxItem          NotificationOutbox?

  @@unique([subscriptionId, oldEventId, newEventId], name: "decision_idempotency_idx")
  @@index([subscriptionId, cycleKey, notificationType, channel])
}

model NotificationOutbox {
  id                String       @id @default(cuid())
  decisionAuditId   String       @unique
  status            OutboxStatus @default(PENDING)
  processAt         DateTime     @default(now())
  idempotencyKey    String       @unique
  frozenPayload     Json
  providerMessageId String?      @unique
  firstAttemptAt    DateTime?
  claimedAt         DateTime?
  claimedByRunId    String?
  expiresAt         DateTime?
  retryCount        Int          @default(0)
  lastError         String?

  decision          NotificationDecisionAudit @relation(fields: [decisionAuditId], references: [id])
  attempts          NotificationAttemptLog[]

  @@index([status, processAt])
}

model NotificationAttemptLog {
  id                String         @id @default(cuid())
  outboxId          String
  attemptedAt       DateTime       @default(now())
  outcome           AttemptOutcome
  errorMessage      String?
  providerMessageId String?
  outbox            NotificationOutbox @relation(fields: [outboxId], references: [id])
}

// ==========================================
// AUTH MODELS
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// SOVEREIGN CORE MODELS (B010)
// ==========================================

model BenefitProgram {
  id                String             @id @default(cuid())
  stateCode         String             // e.g., "NY", "CA"
  name              String             // e.g., "SNAP", "SSI"
  issuanceSchedules IssuanceSchedule[]
  oracleLogs        OracleLog[]
  lastUpdate        DateTime           @updatedAt
  
  @@unique([stateCode, name])
}

model IssuanceSchedule {
  id              String         @id @default(cuid())
  programId       String
  program         BenefitProgram @relation(fields: [programId], references: [id])
  plannedDay      Int            // The raw schedule (e.g., 1st, 15th)
  ssnLastDigit    Int?           // For staggered states like NY/TX
  actualTimestamp DateTime?      // Captured via US-Oracle Bridge (B179)
  isHolidayAdjust Boolean        @default(false) // Triggered by C022 logic
}

model OracleLog {
  id              String         @id @default(cuid())
  programId       String
  program         BenefitProgram @relation(fields: [programId], references: [id])
  predictedDate   DateTime
  actualDate      DateTime?
  confidenceScore Float          // The 0.0 - 1.0 engine score (C011)
  accuracyIndex   Float?         // The OAI for this specific event (C025)
  timestamp       DateTime       @default(now())
}