generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// THE DATA ENGINE (Federal & Gaming Content)
// ==========================================

model Series {
  id             String       @id @default(cuid())
  seriesKey      String       @unique // e.g., "ssa-retirement"
  category       String       @default("benefits") // "benefits" or "gaming"
  canonicalName  String
  entityName     String
  frequency      String
  occurrenceRule String
  updatedAt      DateTime     @updatedAt // CRITICAL: Fixes sitemap "updatedAt" errors
  occurrences    Occurrence[]
}

model Occurrence {
  id                String   @id @default(cuid())
  date              DateTime
  status            String   // "CONFIRMED", "EXPECTED", "ANNOUNCED"
  verificationProof String?  // Links to .gov or official press release
  verifiedAt        DateTime @default(now())
  seriesId          String
  series            Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
}

// ==========================================
// THE AUDIENCE ENGINE (Users & Preferences)
// ==========================================

model User {
  id        String                  @id @default(cuid())
  email     String?                 @unique // Optional for "Anonymous-first" push
  createdAt DateTime                @default(now())
  pushSubs  PushSubscription[]
  topics    UserTopicSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  status    String   @default("ACTIVE") // "ACTIVE", "UNSUBSCRIBED", "INVALID"
  userAgent String?  // Diagnostic data to track device type
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserTopicSubscription {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicKey   String  // e.g., "ssa-2026", "gamescom-2026"
  wantsEmail Boolean @default(false)
  wantsPush  Boolean @default(false)

  @@unique([userId, topicKey]) // Prevents duplicate spam
}

enum CampaignStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum BatchStatus {
  QUEUED
  PROCESSING
  SENT
  PARTIAL
  FAILED
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum TriggerSource {
  CRON
  MANUAL
  RETRY
}

model EmailCampaign {
  id                 String         @id @default(cuid())
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  key                String?        // e.g. "tomorrow-alerts-2026-03-07"
  triggerSource      TriggerSource
  status             CampaignStatus @default(QUEUED)

  templateKey        String
  templateVersion    Int            @default(1)
  subject            String
  payload            Json

  totalRecipients    Int            @default(0)
  batchSize          Int            @default(100)
  totalBatches       Int            @default(0)

  queuedBatches      Int            @default(0)
  processedBatches   Int            @default(0)
  sentCount          Int            @default(0)
  failedCount        Int            @default(0)
  skippedCount       Int            @default(0)

  startedAt          DateTime?
  completedAt        DateTime?
  failedAt           DateTime?
  lastError          String?

  dedupeKey          String?        @unique

  batches            EmailCampaignBatch[]
  recipients         EmailCampaignRecipient[]

  @@index([status, createdAt])
  @@index([templateKey, createdAt])
}

model EmailCampaignBatch {
  id                 String       @id @default(cuid())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  campaignId         String
  campaign           EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  batchIndex         Int
  status             BatchStatus  @default(QUEUED)

  idempotencyKey     String       @unique

  offsetStart        Int
  offsetEndExclusive Int
  recipientCount     Int

  attemptCount       Int          @default(0)
  processedAt        DateTime?
  lastError          String?

  qstashMessageId    String?
  qstashNotBefore    DateTime?

  recipients         EmailCampaignRecipient[]

  @@unique([campaignId, batchIndex])
  @@index([campaignId, status])
}

model EmailCampaignRecipient {
  id                 String          @id @default(cuid())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  campaignId         String
  campaign           EmailCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  batchId            String?
  batch              EmailCampaignBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  userId             String?
  email              String
  normalizedEmail    String

  subject            String?
  payload            Json?

  status             RecipientStatus @default(PENDING)
  sendAttemptCount   Int             @default(0)

  resendEmailId      String?
  sentAt             DateTime?
  failedAt           DateTime?
  lastError          String?

  dedupeKey          String          @unique

  @@index([campaignId, status])
  @@index([batchId, status])
  @@index([normalizedEmail])
}