generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["typedSql"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum EventCategory {
  FEDERAL
  STATE
  TAX
  MARKETS
  GAMING
  SHOPPING
  TECH
  OTHER
}

enum EventDateStatus {
  EXACT
  TBA
  TBD_MONTH
  TBD_QUARTER
  TBD_YEAR
}

enum RecurrenceType {
  NONE
  MONTHLY_FIXED_DAY
  MONTHLY_NTH_WEEKDAY
  MANUAL_DATES
}

enum EventStatus {
  ANNOUNCED
  CONFIRMED
  LIVE
  COMPLETED
}

enum SubmissionStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  DUPLICATE
}

enum NotificationChannel {
  EMAIL
  PUSH
}

enum DeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED_RETRYABLE
  FAILED_FINAL
  INVALID_ENDPOINT
}

enum RuleStatus {
  DRAFT
  REVIEWED
  VERIFIED
  ACTIVE
  SUPERSEDED
}

enum ShiftCause {
  WEEKEND
  HOLIDAY
  BUSINESS_DAY
  NONE
}

enum AppliedPolicy {
  PREVIOUS_BUSINESS_DAY
  NEXT_BUSINESS_DAY
  SAME_DAY
  NO_SHIFT
}

enum OutboxStatus { 
  PENDING
  CLAIMED
  RETRY_SCHEDULED
  SENT
  DEAD_LETTER 
}

enum AttemptOutcome { 
  SUCCESS
  TRANSIENT_FAILURE
  PERMANENT_FAILURE
  PROVIDER_REJECTION 
}

enum IdentifierMatchType { 
  CASE_NUMBER_LAST_DIGIT
  CASE_NUMBER_REMAINDER
  BIRTH_DATE_DAY
  LAST_NAME_INITIAL 
}

enum DecisionReason { 
  DATE_SHIFT_DETECTED
  RULE_CHANGE_NOTIFICATION
  INITIAL_VERIFICATION_SUCCESS 
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
}

// ==========================================
// CORE DATA ENGINE
// ==========================================

model EventSeries {
  id                    String         @id @default(cuid())
  title                 String
  slugBase              String         @unique
  category              EventCategory
  description           String?
  isFeatured            Boolean        @default(false)
  priorityWeight        Int            @default(5)
  heroQuestion          String?
  status                EventStatus    @default(CONFIRMED)
  sourceName            String?
  sourceUrl             String?
  recurrenceType        RecurrenceType @default(NONE)
  dayOfMonth            Int?
  nthWeek               Int?
  weekday               Int?
  startMonth            DateTime?
  endMonth              DateTime?
  autoAdjustBusinessDay Boolean        @default(false)
  generateCount         Int?
  isActive              Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  events                Event[]
}

model Event {
  id               String          @id @default(cuid())
  seriesId         String?
  series           EventSeries?    @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  slug             String          @unique
  title            String
  category         EventCategory
  dueAt            DateTime?
  timeZone         String?
  dateStatus       EventDateStatus @default(EXACT)
  displayYear      Int?
  displayMonth     Int?
  displayQuarter   Int?
  dateLabel        String?
  trending         Boolean         @default(false)
  isGenerated      Boolean         @default(false)
  isDetached       Boolean         @default(false)
  seoTitle         String?
  seoDescription   String?
  keywords         String?
  sourceUrl        String?
  lastVerified     DateTime?
  shortSummary     String?
  whatToExpect     String?
  whereToWatch     String?
  expectedDuration String?
  targetAudience   String?
  scheduleRules    Json?
  faqData          Json?
  isArchived       Boolean         @default(false)
  clickStat        EventClickStat?
  titleSearch      String?         @map("titleSearch")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([dateStatus, dueAt])
  @@index([dueAt])
  @@index([seriesId, dueAt])
}

model EventClickStat {
  id            String    @id @default(cuid())
  eventId       String    @unique
  totalClicks   Int       @default(0)
  clickCount1h  Int       @default(0)
  clickCount24h Int       @default(0)
  lastClickAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([clickCount1h])
  @@index([clickCount24h])
  @@index([lastClickAt])
}

// ==========================================
// INFRASTRUCTURE & ANALYTICS
// ==========================================

model PageStat {
  id              String   @id @default(cuid())
  routePath       String   @unique
  slug            String?
  pageViews       Int      @default(0)
  uniquePageViews Int      @default(0)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model PageViewDedup {
  id         String   @id @default(cuid())
  dedupeKey  String   @unique
  routePath  String
  visitorId  String
  bucketDate String
  createdAt  DateTime @default(now())

  @@index([routePath, bucketDate])
}

model IpRateLimit {
  ipHash       String
  routeKey     String
  windowStart  DateTime
  requestCount Int      @default(0)
  lastSeenAt   DateTime @default(now())

  @@id([ipHash, routeKey, windowStart])
  @@index([lastSeenAt])
}

model EventSubmission {
  id              String           @id @default(cuid())
  status          SubmissionStatus @default(PENDING)
  submittedTitle  String
  submittedDate   String?
  submittedSource String?
  submitterIpHash String?
  userAgent       String?
  honeypot        String?
  reviewerNotes   String?
  duplicateOfId   String?
  titleSearch     String?          @map("titleSearch")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status, createdAt])
}

// ==========================================
// PHASE 9: HARDENED SUBSCRIPTION TIER
// ==========================================

model Subscriber {
  id               String         @id @default(cuid())
  email            String         @unique
  normalizedEmail  String         @unique
  verifiedEmail    String?
  emailVerifiedAt  DateTime?
  unsubscribedAt   DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  subscriptions    Subscription[]
}

model Subscription {
  id              String             @id @default(cuid())
  subscriberId    String
  stateCode       String   
  programName     String   
  identifierValue String   
  status          SubscriptionStatus @default(ACTIVE)
  nextDepositDate DateTime
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  subscriber      Subscriber         @relation(fields: [subscriberId], references: [id])
  decisions       NotificationDecisionAudit[]

  @@unique([subscriberId, stateCode, programName, identifierValue], name: "subscription_identity_key")
  @@index([subscriberId])
}

model RequestLog {
  internalId     String   @id @default(cuid())
  idempotencyKey String   
  subscriberId   String
  action         String   
  payloadHash    String   
  responseStatus Int
  responseBody   Json     
  createdAt      DateTime @default(now())

  @@unique([subscriberId, action, idempotencyKey], name: "request_idempotency_key")
}

// ==========================================
// BITEMPORAL LEDGER & AUDIT ENGINE
// ==========================================

model RuleIdentity {
  id          String            @id @default(cuid())
  stateCode   String
  programCode String
  ruleFamily  String            @default("FULL_SCHEDULE")
  versions    ScheduleRuleSet[]

  @@unique([stateCode, programCode, ruleFamily])
}

model ScheduleRuleSet {
  id                 String           @id @default(cuid())
  identityId         String
  identity           RuleIdentity     @relation(fields: [identityId], references: [id])
  validFrom          DateTime
  validTo            DateTime?
  createdAt          DateTime         @default(now())
  
  // REPAIR: Restoring Audit Fields
  recordedFrom       DateTime         @default(now())
  recordedTo         DateTime?
  status             RuleStatus       @default(DRAFT)
  versionNumber      Int              @default(1)
  changeReason       String?
  verifiedAt         DateTime?
  verifiedBy         String?
  
  identifierKind     String
  issuanceWindow     String
  windowBasis        String
  holidayPolicy      String
  masterSequenceJson Json
  sourceAuthority    String
  sourceUrl          String
  
  paymentEvents      PaymentEvent[]
  notificationAudits NotificationDecisionAudit[]

  @@index([identityId, recordedFrom, recordedTo])
}

model CompilerRun {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  compilerVersion String
  initiatedBy     String?
  note            String?
  paymentEvents   PaymentEvent[]
  notificationAudits NotificationDecisionAudit[]
}

model PaymentEvent {
  id                 String           @id @default(cuid())
  createdAt          DateTime         @default(now())
  batchId            String
  batch              CompilerRun      @relation(fields: [batchId], references: [id])
  ruleSetId          String
  ruleSet            ScheduleRuleSet  @relation(fields: [ruleSetId], references: [id])
  
  // REPAIR: Restoring Audit Fields
  recordedFrom       DateTime         @default(now())
  recordedTo         DateTime?
  
  stateCode          String
  programCode        String
  benefitYear        Int
  benefitMonth       Int
  nominalDepositDay  Int
  depositDate        DateTime
  identifierKind     String
  identifierMatch    String
  isShifted          Boolean          @default(false)
  shiftCause         ShiftCause       @default(NONE)
  appliedPolicy      AppliedPolicy    @default(NO_SHIFT)

  auditsAsOld        NotificationDecisionAudit[] @relation("OldEvent")
  auditsAsNew        NotificationDecisionAudit[] @relation("NewEvent")

  @@index([stateCode, programCode, benefitYear, benefitMonth, recordedFrom, recordedTo])
}

model NotificationDecisionAudit {
  id               String             @id @default(cuid())
  subscriptionId   String
  compilerRunId    String
  compilerRun      CompilerRun        @relation(fields: [compilerRunId], references: [id], onDelete: Restrict)
  ruleSetVersionId String
  ruleSet          ScheduleRuleSet    @relation(fields: [ruleSetVersionId], references: [id], onDelete: Restrict)
  oldEventId       String?
  oldEvent         PaymentEvent?      @relation("OldEvent", fields: [oldEventId], references: [id], onDelete: Restrict)
  newEventId       String?
  newEvent         PaymentEvent?      @relation("NewEvent", fields: [newEventId], references: [id], onDelete: Restrict)
  reason           DecisionReason
  createdAt        DateTime           @default(now())

  subscription     Subscription       @relation(fields: [subscriptionId], references: [id])
  outboxItem       NotificationOutbox?

  @@unique([subscriptionId, oldEventId, newEventId], name: "decision_idempotency_idx")
}

model NotificationOutbox {
  id                String       @id @default(cuid())
  decisionAuditId   String       @unique
  status            OutboxStatus @default(PENDING)
  processAt         DateTime     @default(now())
  idempotencyKey    String       @unique
  frozenPayload     Json
  providerMessageId String?      @unique
  firstAttemptAt    DateTime?
  claimedAt         DateTime?
  claimedByRunId    String?
  expiresAt         DateTime?
  retryCount        Int          @default(0)
  lastError         String?

  decision          NotificationDecisionAudit @relation(fields: [decisionAuditId], references: [id])
  attempts          NotificationAttemptLog[]

  @@index([status, processAt])
}

model NotificationAttemptLog {
  id                String             @id @default(cuid())
  outboxId          String
  attemptedAt       DateTime           @default(now())
  outcome           AttemptOutcome
  errorMessage      String?
  providerMessageId String?
  outbox            NotificationOutbox @relation(fields: [outboxId], references: [id])
}