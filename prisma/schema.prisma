generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["typedSql"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum EventCategory {
  FEDERAL
  STATE
  TAX
  MARKETS
  GAMING
  SHOPPING
  TECH
  OTHER
}

enum EventDateStatus {
  EXACT
  TBA
  TBD_MONTH
  TBD_QUARTER
  TBD_YEAR
}

enum RecurrenceType {
  NONE
  MONTHLY_FIXED_DAY
  MONTHLY_NTH_WEEKDAY
  MANUAL_DATES
}

enum EventStatus {
  ANNOUNCED
  CONFIRMED
  LIVE
  COMPLETED
}

enum SubmissionStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  DUPLICATE
}

enum NotificationChannel {
  EMAIL
  PUSH
}

enum DeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED_RETRYABLE
  FAILED_FINAL
  INVALID_ENDPOINT
}

enum Channel {
  EMAIL
  SMS
}

enum SubStatus {
  PENDING_VERIFICATION
  ACTIVE
  PAUSED
  OUTDATED
}

enum RuleStatus {
  DRAFT
  REVIEWED
  VERIFIED
  ACTIVE
  SUPERSEDED
}

// --- NEW PHASE 5.1 ENUMS ---
enum ShiftCause {
  WEEKEND
  HOLIDAY
  BUSINESS_DAY
  NONE
}

enum AppliedPolicy {
  PREVIOUS_BUSINESS_DAY
  NEXT_BUSINESS_DAY
  SAME_DAY
  NO_SHIFT
}

// ==========================================
// THE LEGACY / GENERIC DATA ENGINE
// ==========================================

model EventSeries {
  id                    String         @id @default(cuid())
  title                 String
  slugBase              String         @unique
  category              EventCategory
  description           String?
  isFeatured            Boolean        @default(false)
  priorityWeight        Int            @default(5)
  heroQuestion          String?
  status                EventStatus    @default(CONFIRMED)
  sourceName            String?
  sourceUrl             String?

  recurrenceType        RecurrenceType @default(NONE)
  dayOfMonth            Int?
  nthWeek               Int?
  weekday               Int?
  startMonth            DateTime?
  endMonth              DateTime?
  autoAdjustBusinessDay Boolean        @default(false)
  generateCount         Int?
  isActive              Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

model Event {
  id         String       @id @default(cuid())
  seriesId   String?
  series     EventSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  slug       String       @unique
  title      String
  category   EventCategory

  dueAt      DateTime?
  timeZone   String?
  dateStatus EventDateStatus @default(EXACT)

  displayYear    Int?
  displayMonth   Int?
  displayQuarter Int?
  dateLabel      String?

  trending    Boolean @default(false)
  isGenerated Boolean @default(false)
  isDetached  Boolean @default(false)

  seoTitle       String?
  seoDescription String?
  keywords       String?
  sourceUrl      String?
  lastVerified   DateTime?

  shortSummary      String?
  whatToExpect      String?
  whereToWatch      String?
  expectedDuration  String?
  targetAudience    String?

  scheduleRules Json?    
  faqData       Json?    

  isArchived  Boolean          @default(false)
  clickStat   EventClickStat?
  titleSearch String?          @map("titleSearch") 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dateStatus, dueAt])
  @@index([dueAt])
  @@index([seriesId, dueAt])
}

model EventClickStat {
  id            String    @id @default(cuid())
  eventId       String    @unique
  totalClicks   Int       @default(0)
  clickCount1h  Int       @default(0)
  clickCount24h Int       @default(0)
  lastClickAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([clickCount1h])
  @@index([clickCount24h])
  @@index([lastClickAt])
}

// ==========================================
// REQUEST & MODERATION ENGINE
// ==========================================

model EventSubmission {
  id              String           @id @default(cuid())
  status          SubmissionStatus @default(PENDING)
  submittedTitle  String
  submittedDate   String?
  submittedSource String?
  submitterIpHash String?
  userAgent       String?
  honeypot        String?
  reviewerNotes   String?
  duplicateOfId   String?
  titleSearch     String?          @map("titleSearch") 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// ==========================================
// NOTIFICATION & ANALYTICS ENGINE
// ==========================================

model NotificationDelivery {
  id                   String              @id @default(cuid())
  eventId              String
  channel              NotificationChannel
  recipientFingerprint String
  status               DeliveryStatus      @default(PENDING)
  attemptCount         Int                 @default(0)
  dedupeKey            String              @unique
  errorLog             String?
  providerMessageId    String?
  scheduledFor         DateTime
  sentAt               DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([status, scheduledFor])
  @@index([eventId])
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String?
  endpoint     String   @unique
  p256dh       String
  auth         String
  isValid      Boolean  @default(true)
  failureCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model UserTopicSubscription {
  id         String  @id @default(cuid())
  userId     String
  topicKey   String
  wantsEmail Boolean @default(false)
  wantsPush  Boolean @default(false)

  @@unique([userId, topicKey])
}

model IpRateLimit {
  ipHash       String
  routeKey     String
  windowStart  DateTime
  requestCount Int      @default(0)
  lastSeenAt   DateTime @default(now())

  @@id([ipHash, routeKey, windowStart])
  @@index([lastSeenAt])
}

model PageStat {
  id              String   @id @default(cuid())
  routePath       String   @unique
  slug            String?
  pageViews       Int      @default(0)
  uniquePageViews Int      @default(0)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model PageViewDedup {
  id         String   @id @default(cuid())
  dedupeKey  String   @unique
  routePath  String
  visitorId  String
  bucketDate String
  createdAt  DateTime @default(now())

  @@index([routePath, bucketDate])
}

// ==========================================
// SUBSCRIPTION ENGINE
// ==========================================

model Subscriber {
  id           String   @id @default(cuid())
  channel      Channel
  contactValue String   @unique
  contactHash  String   @unique 
  timezone     String   @default("America/New_York") 
  createdAt    DateTime @default(now())

  subscriptions Subscription[]
  tokens        VerificationToken[]
}

model Subscription {
  id               String      @id @default(cuid())
  subscriberId     String
  subscriber       Subscriber  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  state            String      
  program          String      
  ruleGroup        String      
  identifierValue  String?    
  status           SubStatus   @default(PENDING_VERIFICATION)
  isActive         Boolean     @default(true)
  ruleVersion      Int         @default(1)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  outbox           NotificationOutbox[]
}

model VerificationToken {
  id           String     @id @default(cuid())
  subscriberId String
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  token        String     @unique 
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
}

model NotificationOutbox {
  id               String       @id @default(cuid())
  subscriptionId   String
  subscription     Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  dedupeKey        String       @unique 
  status           String       @default("PENDING") 
  sendAt           DateTime     
  providerMsgId    String?      
  lastError        String?
  createdAt        DateTime     @default(now())
  sentAt           DateTime?
}

// ==========================================
// BITEMPORAL LEDGER MODELS (M2C1 Engine)
// ==========================================

model RuleIdentity {
  id           String            @id @default(cuid())
  stateCode    String
  programCode  String
  ruleFamily   String            @default("FULL_SCHEDULE")
  versions     ScheduleRuleSet[]
  
  @@unique([stateCode, programCode, ruleFamily])
}

model ScheduleRuleSet {
  id                String        @id @default(cuid())
  identityId        String
  identity          RuleIdentity  @relation(fields: [identityId], references: [id])
  
  validFrom         DateTime      
  validTo           DateTime?     
  
  createdAt         DateTime      @default(now())
  recordedFrom      DateTime      @default(now())
  recordedTo        DateTime?     // Null = ACTIVE
  
  status            RuleStatus    @default(DRAFT)
  versionNumber     Int           @default(1)
  changeReason      String?       
  supersedesId      String?       @unique
  supersedes        ScheduleRuleSet? @relation("Lineage", fields: [supersedesId], references: [id])
  predecessorOf     ScheduleRuleSet? @relation("Lineage")
  
  identifierKind     String   
  issuanceWindow     String   
  windowBasis        String   
  holidayPolicy      String   
  masterSequenceJson Json     

  sourceAuthority   String
  sourceUrl         String
  verifiedAt        DateTime?
  verifiedBy        String?
  
  paymentEvents     PaymentEvent[]

  @@index([identityId, recordedFrom, recordedTo])
  @@index([validFrom, validTo])
}

model CompilerRun {
  id              String         @id @default(cuid())
  createdAt       DateTime       @default(now())
  compilerVersion String
  initiatedBy     String?        
  note            String?
  paymentEvents   PaymentEvent[]
}

model PaymentEvent {
  id              String           @id @default(cuid())
  createdAt       DateTime         @default(now())
  
  batchId         String
  batch           CompilerRun      @relation(fields: [batchId], references: [id])
  ruleSetId       String
  ruleSet         ScheduleRuleSet  @relation(fields: [ruleSetId], references: [id])
  
  recordedFrom    DateTime         @default(now())
  recordedTo      DateTime?        
  
  stateCode       String
  programCode     String
  benefitYear     Int
  benefitMonth    Int
  nominalDepositDay Int            
  depositDate     DateTime
  identifierKind  String
  identifierMatch String
  isShifted       Boolean          @default(false)

  // AUDIT FIELDS
  shiftCause      ShiftCause       @default(NONE)
  appliedPolicy   AppliedPolicy    @default(NO_SHIFT)

  @@index([stateCode, programCode, benefitYear, benefitMonth, identifierKind, identifierMatch, recordedFrom, recordedTo])
}